# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://bankuser:bankpass@localhost:5432/ai_me_bank_db
DATABASE_SYNC_URL=postgresql://bankuser:bankpass@localhost:5432/ai_me_bank_db

# ── Redis / Celery ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Observability ──────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Core Banking System ────────────────────────────────────────────────────
CBS_BASE_URL=https://api.your-cbs.com/v1
CBS_CLIENT_ID=your_client_id
CBS_CLIENT_SECRET=your_client_secret

# ── Credit Bureau (CIBIL / Experian) ───────────────────────────────────────
BUREAU_API_URL=https://api.cibil.com/v1
BUREAU_API_KEY=your_bureau_key

# ── Account Aggregator (Sahamati / Setu / Finvu) ───────────────────────────
AA_BASE_URL=https://api.your-aa-provider.com/v2
AA_CLIENT_ID=your_aa_client_id
AA_CLIENT_SECRET=your_aa_client_secret

# ── GST / Tax ──────────────────────────────────────────────────────────────
GST_API_URL=https://api.gst.gov.in/v1
GST_API_KEY=your_gst_key

# ── OCR (financial document extraction) ────────────────────────────────────
OCR_API_URL=https://api.your-ocr-provider.com/v1
OCR_API_KEY=your_ocr_key

# ── AML / Watchlist Screening ──────────────────────────────────────────────
AML_WATCHLIST_API_URL=https://api.your-aml-provider.com/v1
AML_WATCHLIST_API_KEY=your_aml_key

# ── Transaction Feed (card/UPI/IMPS signals) ───────────────────────────────
TXN_FEED_API_URL=https://api.your-fraud-signals-provider.com/v1
TXN_FEED_API_KEY=your_txn_feed_key

# ── WhatsApp / Meta ────────────────────────────────────────────────────────
WHATSAPP_API_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_verify_token

# ── SMS Gateway ────────────────────────────────────────────────────────────
SMS_GATEWAY_URL=https://api.your-sms-provider.com/v1
SMS_GATEWAY_KEY=your_sms_key

# ── IVR / Voice ────────────────────────────────────────────────────────────
IVR_API_URL=https://api.your-ivr-provider.com/v1
IVR_API_KEY=your_ivr_key

# ── Slack (internal ops escalation) ────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=your_signing_secret
SLACK_CREDIT_CHANNEL_ID=C0XXXXXXXX
SLACK_FRAUD_CHANNEL_ID=C0YYYYYYYY
SLACK_COLLECTIONS_CHANNEL_ID=C0ZZZZZZZZ

# ── Security ──────────────────────────────────────────────────────────────
PII_ENCRYPTION_KEY=your_32_byte_hex_key_here
JWT_SECRET_KEY=your_jwt_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── App ────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO
BANK_NAME=Ai-ME BANK
